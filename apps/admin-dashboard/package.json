{
  "name": "@rift/admin-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --watch server/server.ts",
    "dev:web": "vite",
    "start": "bun server/server.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.6.9",
    "hono": "^4.12.16",
    "lucide-react": "^1.14.0",
    "pg": "^8.20.0",
    "pg-logical-replication": "^2.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
