{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rift Documentation",
  "js": "/scripts/custom.js",
  "colors": {
    "primary": "#fe8f21",
    "light": "#fe8f21",
    "dark": "#fe8f21"
  },
  "favicon": "/images/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "openapi": {
          "source": "/openapi.json",
          "directory": "api"
        },
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction/what-is-rift",
              "introduction/multichain-smart-contracts",
              "use-cases",
              "security-model"
            ]
          },
          {
            "group": "API Endpoints",
            "pages": [
              "POST /quote",
              "POST /order/market",
              "POST /order/{orderId}/cancel",
              "GET /health",
              "GET /providers"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/light.svg",
    "dark": "/images/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Chat with team",
      "href": "https://t.me/samee_rift"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/riftdex",
      "github": "https://github.com/riftresearch"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "prefill": true
    }
  }
}
