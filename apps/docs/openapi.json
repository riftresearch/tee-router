{
  "openapi": "3.1.0",
  "info": {
    "title": "TEE Router Gateway API",
    "version": "0.1.0",
    "description": "Public TypeScript API gateway for quote and order access to the TEE router protocol."
  },
  "servers": [
    {
      "url": "https://router-gateway-production.up.railway.app",
      "description": "Production"
    }
  ],
  "components": {
    "schemas": {
      "QuoteResponse": {
        "type": "object",
        "properties": {
          "quoteId": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "expiry": {
            "type": "string"
          },
          "expectedOut": {
            "type": "string"
          },
          "expectedSlippage": {
            "type": "string"
          },
          "minOut": {
            "type": "string"
          },
          "maxIn": {
            "type": "string"
          },
          "maxSlippage": {
            "type": "string"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "required": [
          "quoteId",
          "from",
          "to",
          "expiry",
          "expectedOut",
          "maxSlippage"
        ]
      },
      "AmountFormat": {
        "type": "string",
        "enum": [
          "readable",
          "raw"
        ],
        "default": "readable"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {}
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "QuoteRequest": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "example": "Ethereum.USDC"
          },
          "toAddress": {
            "type": "string",
            "minLength": 1,
            "description": "Current Rust router quote bridge field. The upstream router requires a recipient address at quote time.",
            "example": "0x1111111111111111111111111111111111111111"
          },
          "fromAmount": {
            "type": "string",
            "minLength": 1,
            "example": "10"
          },
          "toAmount": {
            "type": "string",
            "minLength": 1,
            "example": "100000"
          },
          "maxSlippage": {
            "type": "string",
            "minLength": 1,
            "example": "1.5"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "required": [
          "from",
          "to",
          "toAddress",
          "maxSlippage"
        ],
        "additionalProperties": false
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "orderAddress": {
            "type": "string"
          },
          "amountToSend": {
            "type": "string"
          },
          "quoteId": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "expiry": {
            "type": "string"
          },
          "expectedOut": {
            "type": "string"
          },
          "expectedSlippage": {
            "type": "string"
          },
          "minOut": {
            "type": "string"
          },
          "maxIn": {
            "type": "string"
          },
          "maxSlippage": {
            "type": "string"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ]
          },
          "refundToken": {
            "type": "string"
          }
        },
        "required": [
          "orderId",
          "orderAddress",
          "amountToSend",
          "quoteId",
          "from",
          "to",
          "status",
          "expiry",
          "expectedOut",
          "maxSlippage"
        ]
      },
      "RefundMode": {
        "type": "string",
        "enum": [
          "evmSignature",
          "token"
        ],
        "default": "evmSignature"
      },
      "OrderMarketRequest": {
        "type": "object",
        "properties": {
          "quoteId": {
            "type": "string",
            "format": "uuid"
          },
          "fromAddress": {
            "type": "string",
            "minLength": 1
          },
          "toAddress": {
            "type": "string",
            "minLength": 1
          },
          "refundAddress": {
            "type": "string",
            "minLength": 1
          },
          "integrator": {
            "type": "string",
            "minLength": 1
          },
          "idempotencyKey": {
            "type": "string",
            "minLength": 1
          },
          "cancelAfter": {
            "type": "string",
            "format": "date-time"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "required": [
          "quoteId",
          "fromAddress",
          "toAddress",
          "refundAuthorizer"
        ],
        "additionalProperties": false
      },
      "OrderCancelRequest": {
        "type": "object",
        "properties": {
          "refundToken": {
            "type": "string",
            "minLength": 1
          },
          "refundSignature": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]+$"
          },
          "refundSignatureDeadline": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "timestamp"
        ]
      },
      "DependencyHealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "reachable",
                    "unreachable",
                    "unknown"
                  ]
                },
                "checkedAt": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "name",
                "status"
              ]
            }
          }
        },
        "required": [
          "status",
          "timestamp",
          "dependencies"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/quote": {
      "post": {
        "tags": [
          "Quotes"
        ],
        "summary": "Create a quote for a market order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Market quote created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/market": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Create a market order from a quote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderMarketRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Market order created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/{orderId}/cancel": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Cancel an order via specified authentication",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "orderId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCancelRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order cancellation accepted by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Get Rift online status",
        "description": "Returns the online status of the Rift API.",
        "responses": {
          "200": {
            "description": "Rift online status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/providers": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Get execution provider online status",
        "description": "Returns cached execution provider online checks from the router worker.",
        "responses": {
          "200": {
            "description": "Cached execution provider online status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DependencyHealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
