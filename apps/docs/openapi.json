{
  "openapi": "3.1.0",
  "info": {
    "title": "TEE Router Gateway API",
    "version": "0.1.0",
    "description": "Public TypeScript API gateway for quote and order access to the TEE router protocol."
  },
  "servers": [
    {
      "url": "https://router-gateway-v3-production.up.railway.app",
      "description": "Production"
    }
  ],
  "components": {
    "schemas": {
      "QuoteResponse": {
        "type": "object",
        "properties": {
          "quoteId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "orderType": {
            "type": "string",
            "enum": [
              "market_order"
            ],
            "example": "market_order"
          },
          "from": {
            "type": "string",
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "example": "Ethereum.USDC"
          },
          "expiry": {
            "type": "string",
            "example": "2026-05-04T12:10:00Z"
          },
          "estimatedOut": {
            "type": "string",
            "example": "100000"
          },
          "venues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered provider ids for the route transitions used by this quote.",
            "example": [
              "velora",
              "across",
              "hyperliquid_bridge",
              "hyperliquid_spot",
              "unit"
            ]
          },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "example": "hyperliquid_core_activation_fee"
                },
                "label": {
                  "type": "string",
                  "example": "Hyperliquid activation fee"
                },
                "asset": {
                  "type": "string",
                  "example": "Hyperliquid.USDC"
                },
                "amount": {
                  "type": "string",
                  "example": "1"
                },
                "amountRaw": {
                  "type": "string",
                  "example": "1000000"
                }
              },
              "required": [
                "kind",
                "label",
                "asset",
                "amount",
                "amountRaw"
              ]
            }
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "required": [
          "quoteId",
          "orderType",
          "from",
          "to",
          "expiry",
          "estimatedOut",
          "venues"
        ]
      },
      "AmountFormat": {
        "type": "string",
        "enum": [
          "readable",
          "raw"
        ],
        "default": "readable",
        "example": "readable"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "invalid_request"
              },
              "message": {
                "type": "string",
                "example": "Invalid gateway request."
              },
              "details": {
                "example": {
                  "field": "fromAmount"
                }
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "QuoteRequest": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "maxLength": 96,
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "maxLength": 96,
            "example": "Ethereum.USDC"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "toAddress": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Current Rust router quote bridge field. The upstream router requires a recipient address at quote time.",
            "example": "0x1111111111111111111111111111111111111111"
          },
          "orderType": {
            "type": "string",
            "enum": [
              "market_order",
              "market"
            ],
            "description": "Order type. Defaults to market_order.",
            "example": "market_order"
          },
          "fromAmount": {
            "type": "string",
            "minLength": 1,
            "maxLength": 96,
            "example": "10"
          }
        },
        "required": [
          "from",
          "to",
          "toAddress"
        ],
        "additionalProperties": false
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000002"
          },
          "orderAddress": {
            "type": "string",
            "example": "bc1qorderaddress0000000000000000000000000"
          },
          "amountToSend": {
            "type": "string",
            "example": "10"
          },
          "quoteId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "orderType": {
            "type": "string",
            "enum": [
              "market_order"
            ],
            "example": "market_order"
          },
          "from": {
            "type": "string",
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "example": "Ethereum.USDC"
          },
          "status": {
            "type": "string",
            "example": "quoted"
          },
          "expiry": {
            "type": "string",
            "example": "2026-05-04T12:10:00Z"
          },
          "estimatedOut": {
            "type": "string",
            "example": "100000"
          },
          "venues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered provider ids for the route transitions used by this quote.",
            "example": [
              "velora",
              "across",
              "hyperliquid_bridge",
              "hyperliquid_spot",
              "unit"
            ]
          },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "example": "hyperliquid_core_activation_fee"
                },
                "label": {
                  "type": "string",
                  "example": "Hyperliquid activation fee"
                },
                "asset": {
                  "type": "string",
                  "example": "Hyperliquid.USDC"
                },
                "amount": {
                  "type": "string",
                  "example": "1"
                },
                "amountRaw": {
                  "type": "string",
                  "example": "1000000"
                }
              },
              "required": [
                "kind",
                "label",
                "asset",
                "amount",
                "amountRaw"
              ]
            }
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "example": "0x2222222222222222222222222222222222222222"
          },
          "refundToken": {
            "type": "string",
            "example": "rgt_abcdefghijklmnopqrstuvwxyz"
          }
        },
        "required": [
          "orderId",
          "orderAddress",
          "amountToSend",
          "quoteId",
          "orderType",
          "from",
          "to",
          "status",
          "expiry",
          "estimatedOut",
          "venues"
        ]
      },
      "RefundMode": {
        "type": "string",
        "enum": [
          "evmSignature",
          "token"
        ],
        "default": "evmSignature",
        "example": "evmSignature"
      },
      "OrderMarketRequest": {
        "type": "object",
        "properties": {
          "quoteId": {
            "type": "string",
            "format": "uuid"
          },
          "fromAddress": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "toAddress": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "refundAddress": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "integrator": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "idempotencyKey": {
            "type": "string",
            "minLength": 16,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 128
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "required": [
          "quoteId",
          "fromAddress",
          "toAddress",
          "idempotencyKey",
          "refundAuthorizer"
        ],
        "additionalProperties": false
      },
      "OrderCancellationResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000002"
          },
          "orderAddress": {
            "type": "string",
            "example": "bc1qorderaddress0000000000000000000000000"
          },
          "amountToSend": {
            "type": "string",
            "example": "10"
          },
          "quoteId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "orderType": {
            "type": "string",
            "enum": [
              "market_order"
            ],
            "example": "market_order"
          },
          "from": {
            "type": "string",
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "example": "Ethereum.USDC"
          },
          "status": {
            "type": "string",
            "example": "quoted"
          },
          "expiry": {
            "type": "string",
            "example": "2026-05-04T12:10:00Z"
          },
          "estimatedOut": {
            "type": "string",
            "example": "100000"
          },
          "venues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered provider ids for the route transitions used by this quote.",
            "example": [
              "velora",
              "across",
              "hyperliquid_bridge",
              "hyperliquid_spot",
              "unit"
            ]
          },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "example": "hyperliquid_core_activation_fee"
                },
                "label": {
                  "type": "string",
                  "example": "Hyperliquid activation fee"
                },
                "asset": {
                  "type": "string",
                  "example": "Hyperliquid.USDC"
                },
                "amount": {
                  "type": "string",
                  "example": "1"
                },
                "amountRaw": {
                  "type": "string",
                  "example": "1000000"
                }
              },
              "required": [
                "kind",
                "label",
                "asset",
                "amount",
                "amountRaw"
              ]
            }
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "example": "0x2222222222222222222222222222222222222222"
          },
          "refundToken": {
            "type": "string",
            "example": "rgt_abcdefghijklmnopqrstuvwxyz"
          }
        },
        "required": [
          "orderId",
          "orderAddress",
          "amountToSend",
          "quoteId",
          "orderType",
          "from",
          "to",
          "status",
          "expiry",
          "estimatedOut",
          "venues"
        ]
      },
      "OrderCancelRequest": {
        "type": "object",
        "properties": {
          "refundToken": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "refundSignature": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{130}$"
          },
          "refundSignatureDeadline": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ],
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-04T12:00:00.000Z"
          }
        },
        "required": [
          "status",
          "timestamp"
        ]
      },
      "DependencyHealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ],
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-04T12:00:00.000Z"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "hyperliquid_spot"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "reachable",
                    "unreachable",
                    "unknown"
                  ],
                  "example": "reachable"
                },
                "checkedAt": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2026-05-04T12:00:00.000Z"
                }
              },
              "required": [
                "name",
                "status"
              ]
            }
          }
        },
        "required": [
          "status",
          "timestamp",
          "dependencies"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/quote": {
      "post": {
        "tags": [
          "Quotes"
        ],
        "summary": "Get a market quote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Market quote created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Gateway request conflicts with an in-progress or completed operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Gateway request body is too large.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Internal router API timed out.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/market": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Create a market order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderMarketRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Gateway request conflicts with an in-progress or completed operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Gateway request body is too large.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Internal router API timed out.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/{orderId}/cancel": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Cancel an order via specified authentication",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "00000000-0000-4000-8000-000000000002"
            },
            "required": true,
            "name": "orderId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCancelRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order cancellation accepted by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderCancellationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Gateway request conflicts with an in-progress or completed operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Gateway request body is too large.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Internal router API timed out.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Check Rift online status",
        "description": "Returns the online status of the Rift API.",
        "responses": {
          "200": {
            "description": "Rift online status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/providers": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Check execution provider online status",
        "description": "Returns cached execution provider online checks from the router worker.",
        "responses": {
          "200": {
            "description": "Cached execution provider online status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DependencyHealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
