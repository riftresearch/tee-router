{
  "openapi": "3.1.0",
  "info": {
    "title": "TEE Router Gateway API",
    "version": "0.1.0",
    "description": "Public TypeScript API gateway for quote and order access to the TEE router protocol."
  },
  "servers": [
    {
      "url": "https://router-gateway-production.up.railway.app",
      "description": "Production"
    }
  ],
  "components": {
    "schemas": {
      "QuoteResponse": {
        "type": "object",
        "properties": {
          "quoteId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "from": {
            "type": "string",
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "example": "Ethereum.USDC"
          },
          "expiry": {
            "type": "string",
            "example": "2026-05-04T12:10:00Z"
          },
          "expectedOut": {
            "type": "string",
            "example": "100000"
          },
          "expectedSlippage": {
            "type": "string",
            "example": "0.2"
          },
          "minOut": {
            "type": "string",
            "example": "99000"
          },
          "maxIn": {
            "type": "string",
            "example": "10.1"
          },
          "maxSlippage": {
            "type": "string",
            "example": "1.5"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          }
        },
        "required": [
          "quoteId",
          "from",
          "to",
          "expiry",
          "expectedOut",
          "maxSlippage"
        ]
      },
      "AmountFormat": {
        "type": "string",
        "enum": [
          "readable",
          "raw"
        ],
        "default": "readable",
        "example": "readable"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "invalid_request"
              },
              "message": {
                "type": "string",
                "example": "Invalid gateway request."
              },
              "details": {
                "example": {
                  "field": "fromAmount"
                }
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "QuoteRequest": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "example": "Ethereum.USDC"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "toAddress": {
            "type": "string",
            "minLength": 1,
            "description": "Current Rust router quote bridge field. The upstream router requires a recipient address at quote time.",
            "example": "0x1111111111111111111111111111111111111111"
          },
          "fromAmount": {
            "type": "string",
            "minLength": 1,
            "example": "10"
          },
          "toAmount": {
            "type": "string",
            "minLength": 1,
            "example": "100000"
          },
          "maxSlippage": {
            "type": "string",
            "minLength": 1,
            "example": "1.5"
          }
        },
        "required": [
          "from",
          "to",
          "toAddress",
          "maxSlippage"
        ],
        "additionalProperties": false
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000002"
          },
          "orderAddress": {
            "type": "string",
            "example": "bc1qorderaddress0000000000000000000000000"
          },
          "amountToSend": {
            "type": "string",
            "example": "10"
          },
          "quoteId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "from": {
            "type": "string",
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "example": "Ethereum.USDC"
          },
          "status": {
            "type": "string",
            "example": "quoted"
          },
          "expiry": {
            "type": "string",
            "example": "2026-05-04T12:10:00Z"
          },
          "expectedOut": {
            "type": "string",
            "example": "100000"
          },
          "expectedSlippage": {
            "type": "string",
            "example": "0.2"
          },
          "minOut": {
            "type": "string",
            "example": "99000"
          },
          "maxIn": {
            "type": "string",
            "example": "10.1"
          },
          "maxSlippage": {
            "type": "string",
            "example": "1.5"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "example": "0x2222222222222222222222222222222222222222"
          },
          "refundToken": {
            "type": "string",
            "example": "rgt_abcdefghijklmnopqrstuvwxyz"
          }
        },
        "required": [
          "orderId",
          "orderAddress",
          "amountToSend",
          "quoteId",
          "from",
          "to",
          "status",
          "expiry",
          "expectedOut",
          "maxSlippage"
        ]
      },
      "RefundMode": {
        "type": "string",
        "enum": [
          "evmSignature",
          "token"
        ],
        "default": "evmSignature",
        "example": "evmSignature"
      },
      "OrderMarketRequest": {
        "type": "object",
        "properties": {
          "quoteId": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "fromAddress": {
            "type": "string",
            "minLength": 1,
            "example": "bc1qexample000000000000000000000000000000"
          },
          "toAddress": {
            "type": "string",
            "minLength": 1,
            "example": "0x1111111111111111111111111111111111111111"
          },
          "refundAddress": {
            "type": "string",
            "minLength": 1,
            "example": "bc1qrefund0000000000000000000000000000000"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "example": "0x2222222222222222222222222222222222222222"
          },
          "integrator": {
            "type": "string",
            "minLength": 1,
            "example": "partner-a"
          },
          "idempotencyKey": {
            "type": "string",
            "minLength": 1,
            "example": "partner-a-market-order-0001"
          },
          "cancelAfter": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-04T13:00:00Z"
          }
        },
        "required": [
          "quoteId",
          "fromAddress",
          "toAddress",
          "refundAuthorizer"
        ],
        "additionalProperties": false
      },
      "LimitOrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000002"
          },
          "orderAddress": {
            "type": "string",
            "example": "bc1qorderaddress0000000000000000000000000"
          },
          "amountToSend": {
            "type": "string",
            "example": "10"
          },
          "quoteId": {
            "type": "string",
            "example": "00000000-0000-4000-8000-000000000003"
          },
          "from": {
            "type": "string",
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "example": "Ethereum.USDC"
          },
          "status": {
            "type": "string",
            "example": "quoted"
          },
          "expiry": {
            "type": "string",
            "example": "2026-05-04T12:10:00Z"
          },
          "minOut": {
            "type": "string",
            "example": "100000"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "example": "0x2222222222222222222222222222222222222222"
          },
          "refundToken": {
            "type": "string",
            "example": "rgt_abcdefghijklmnopqrstuvwxyz"
          }
        },
        "required": [
          "orderId",
          "orderAddress",
          "amountToSend",
          "quoteId",
          "from",
          "to",
          "status",
          "expiry",
          "minOut"
        ]
      },
      "OrderLimitRequest": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "example": "Bitcoin.BTC"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "example": "Ethereum.USDC"
          },
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "fromAddress": {
            "type": "string",
            "minLength": 1,
            "example": "bc1qexample000000000000000000000000000000"
          },
          "toAddress": {
            "type": "string",
            "minLength": 1,
            "example": "0x1111111111111111111111111111111111111111"
          },
          "fromAmount": {
            "type": "string",
            "minLength": 1,
            "example": "10"
          },
          "toAmount": {
            "type": "string",
            "minLength": 1,
            "example": "1000000"
          },
          "price": {
            "type": "string",
            "minLength": 1,
            "example": "100000"
          },
          "expiration": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-04T13:00:00Z"
          },
          "refundAddress": {
            "type": "string",
            "minLength": 1,
            "example": "bc1qrefund0000000000000000000000000000000"
          },
          "refundMode": {
            "$ref": "#/components/schemas/RefundMode"
          },
          "refundAuthorizer": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "example": "0x2222222222222222222222222222222222222222"
          },
          "integrator": {
            "type": "string",
            "minLength": 1,
            "example": "partner-a"
          },
          "idempotencyKey": {
            "type": "string",
            "minLength": 1,
            "example": "partner-a-limit-order-0001"
          }
        },
        "required": [
          "from",
          "to",
          "fromAddress",
          "toAddress",
          "refundAuthorizer"
        ],
        "additionalProperties": false
      },
      "OrderCancellationResponse": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/OrderResponse"
          },
          {
            "$ref": "#/components/schemas/LimitOrderResponse"
          }
        ]
      },
      "OrderCancelRequest": {
        "type": "object",
        "properties": {
          "amountFormat": {
            "$ref": "#/components/schemas/AmountFormat"
          },
          "refundToken": {
            "type": "string",
            "minLength": 1,
            "example": "rgt_abcdefghijklmnopqrstuvwxyz"
          },
          "refundSignature": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]+$",
            "example": "0xabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd"
          },
          "refundSignatureDeadline": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "example": 1777899600
          }
        },
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ],
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-04T12:00:00.000Z"
          }
        },
        "required": [
          "status",
          "timestamp"
        ]
      },
      "DependencyHealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ],
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-04T12:00:00.000Z"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "hyperliquid"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "reachable",
                    "unreachable",
                    "unknown"
                  ],
                  "example": "reachable"
                },
                "checkedAt": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2026-05-04T12:00:00.000Z"
                }
              },
              "required": [
                "name",
                "status"
              ]
            }
          }
        },
        "required": [
          "status",
          "timestamp",
          "dependencies"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/quote": {
      "post": {
        "tags": [
          "Quotes"
        ],
        "summary": "Create a quote for a market order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Market quote created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/market": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Create a market order from a quote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderMarketRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Market order created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/limit": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Create a limit order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderLimitRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Limit order created by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LimitOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/order/{orderId}/cancel": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Cancel an order via specified authentication",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "00000000-0000-4000-8000-000000000002"
            },
            "required": true,
            "name": "orderId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCancelRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order cancellation accepted by the internal router API.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderCancellationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid gateway request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Gateway authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected gateway error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Internal router API error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Gateway is not configured for this operation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Get Rift online status",
        "description": "Returns the online status of the Rift API.",
        "responses": {
          "200": {
            "description": "Rift online status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/providers": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Get execution provider online status",
        "description": "Returns cached execution provider online checks from the router worker.",
        "responses": {
          "200": {
            "description": "Cached execution provider online status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DependencyHealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
