{
  "name": "tee-router",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "explorer:dev": "bun --filter @rift/explorer dev",
    "explorer:build": "bun --filter @rift/explorer build",
    "explorer:start": "bun --filter @rift/explorer start",
    "explorer:lint": "bun --filter @rift/explorer lint",
    "explorer:typecheck": "bun --filter @rift/explorer typecheck",
    "router-gateway:dev": "bun --filter @rift/router-gateway dev",
    "router-gateway:migrate": "bun --filter @rift/router-gateway migrate",
    "router-gateway:start": "bun --filter @rift/router-gateway start",
    "router-gateway:test": "bun --filter @rift/router-gateway test",
    "router-gateway:typecheck": "bun --filter @rift/router-gateway typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
