#!/bin/sh
set -eu

if git diff --cached --name-only -- apps/docs | grep -q .; then
  # Store only the SHA-256 digest here, never the approval password itself.
  # Generate a digest with:
  #   printf '%s' 'your-human-only-password' | sha256sum | cut -d' ' -f1
  DOCS_HUMAN_APPROVAL_SHA256="168ee09f96df4c38849d14d6b72b238995289c6014d8602d1c0b71f0db58c429"
  DOCS_HUMAN_APPROVAL_SHA256_UNSET="__SET_DOCS_HUMAN_APPROVAL_SHA256__"

  if [ "$DOCS_HUMAN_APPROVAL_SHA256" != "$DOCS_HUMAN_APPROVAL_SHA256_UNSET" ]; then
    if [ -n "${DOCS_HUMAN_APPROVAL:-}" ]; then
      provided_hash="$(printf '%s' "$DOCS_HUMAN_APPROVAL" | sha256sum | cut -d' ' -f1)"
      if [ "$provided_hash" = "$DOCS_HUMAN_APPROVAL_SHA256" ]; then
        echo "Docs approval password accepted; allowing docs commit." >&2
        exit 0
      fi
    fi
  fi

  cat >&2 <<'EOF'

ERROR: This commit includes changes under apps/docs.

A human must review and approve docs changes before committing.
Set DOCS_HUMAN_APPROVAL to the human-only approval password before committing.

The hook must contain the SHA-256 hash of that password, not the password itself.
EOF

  exit 1
fi
