FROM rust:1.90.0-trixie AS chef
RUN cargo install cargo-chef --locked
WORKDIR /app

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json
COPY . .
RUN cargo build --release -p devnet-cli

FROM rust:1.90.0-trixie

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    nodejs \
    npm \
    pkg-config \
    libssl-dev \
    && npm install -g pnpm \
    && curl -L https://foundry.paradigm.xyz | bash \
    && /root/.foundry/bin/foundryup \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.foundry/bin:${PATH}"

WORKDIR /app
COPY --from=builder /app/target/release/devnet /usr/local/bin/devnet
COPY --from=builder /app/target/release/build /tmp/devnet-build
RUN install -m 0755 "$(find /tmp/devnet-build -path '*/out/bitcoin/*/bin/bitcoind' -type f | head -n 1)" /usr/local/bin/bitcoind \
    && install -m 0755 "$(find /tmp/devnet-build -path '*/out/electrs/*/electrs' -type f | head -n 1)" /usr/local/bin/electrs \
    && rm -rf /tmp/devnet-build
WORKDIR /app/evm-token-indexer
COPY evm-token-indexer/package.json evm-token-indexer/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
WORKDIR /app
COPY evm-token-indexer ./evm-token-indexer

ENV BITCOIND_EXE=/usr/local/bin/bitcoind
ENV ELECTRS_EXE=/usr/local/bin/electrs

EXPOSE 50100 50101 50102 50103 50104 50105 50106 50107 50108 50110 50111 50112

CMD ["devnet", "server"]
