# Copy to .env.live-local and fill with dedicated live-local values.
#
# This stack uses real networks and can move real funds. Do not use production
# custody/admin secrets. Use small, isolated wallets and RPC credentials.

TEE_ROUTER_LIVE_LOCAL_ACK=I_UNDERSTAND_THIS_USES_REAL_FUNDS

# 64 bytes / 128 hex characters. Generate a dedicated value, do not reuse prod.
ROUTER_LIVE_LOCAL_MASTER_KEY_HEX=<128-hex-character-live-local-master-key>

# Local API keys shared between the local gateway/admin/Sauron/router services.
ROUTER_DETECTOR_API_KEY=<live-local-detector-api-key>
ROUTER_GATEWAY_API_KEY=<live-local-gateway-api-key>
ROUTER_ADMIN_API_KEY=<live-local-admin-api-key>
ROUTER_GATEWAY_CANCELLATION_SECRET_KEY=<64-hex-character-cancellation-secret>

# Keep false for local quote-only testing; Phala quote-only deployments set true.
ROUTER_ORDERS_DISABLED=false
ROUTER_MARKET_ORDER_QUOTE_TIMEOUT_MS=60000
ROUTER_SINGLE_HOP_QUOTE_TIMEOUT_MS=5000

# EVM RPCs. Receipt watchers for Ethereum/Base/Arbitrum use websocket endpoints.
ETH_RPC_URL=https://example-ethereum-rpc
ETH_WS_RPC_URL=wss://example-ethereum-ws
BASE_RPC_URL=https://example-base-rpc
BASE_WS_RPC_URL=wss://example-base-ws
ARBITRUM_RPC_URL=https://example-arbitrum-rpc
ARBITRUM_WS_RPC_URL=wss://example-arbitrum-ws

# Dedicated small paymaster wallets for live-local only.
ETHEREUM_PAYMASTER_PRIVATE_KEY=<0x-private-key>
BASE_PAYMASTER_PRIVATE_KEY=<0x-private-key>
ARBITRUM_PAYMASTER_PRIVATE_KEY=<0x-private-key>
HYPERLIQUID_PAYMASTER_PRIVATE_KEY=<0x-private-key>

# Bitcoin mainnet node / esplora endpoints.
BITCOIN_NETWORK=bitcoin
BITCOIN_RPC_URL=http://host.docker.internal:8332
BITCOIN_RPC_AUTH=<rpc-user>:<rpc-password>
ESPLORA_HTTP_SERVER_URL=http://host.docker.internal:3002
BITCOIN_ZMQ_RAWBLOCK_ENDPOINT=tcp://host.docker.internal:28332
BITCOIN_ZMQ_RAWTX_ENDPOINT=tcp://host.docker.internal:28333
BITCOIN_ZMQ_SEQUENCE_ENDPOINT=
ROUTER_GATEWAY_BITCOIN_ADDRESS_NETWORKS=mainnet

# Optional: reuse already-deployed Bitcoin observer services instead of the
# local bitcoin-indexer / bitcoin-receipt-watcher containers.
BITCOIN_INDEXER_URL=http://bitcoin-indexer:8080
BITCOIN_RECEIPT_WATCHER_URL=http://bitcoin-receipt-watcher:8080

# Local live token indexers. Compose starts one Ponder indexer per EVM chain and
# resolves each start block from the configured RPC at container startup.
TOKEN_INDEXER_API_KEY=<token-indexer-api-key>
EVM_TOKEN_INDEXER_PONDER_LOG_LEVEL=info
EVM_TOKEN_INDEXER_DISABLE_CACHE=false
EVM_TOKEN_INDEXER_RAW_RETENTION_SECONDS=604800
EVM_TOKEN_INDEXER_REORG_SAFE_BLOCKS=64
EVM_TOKEN_INDEXER_WS_MAX_BUFFERED_BYTES=8388608

# Provider APIs.
ACROSS_API_URL=https://app.across.to/api
ACROSS_API_KEY=
ACROSS_INTEGRATOR_ID=rift-live-local
CCTP_API_URL=https://iris-api.circle.com
CCTP_TOKEN_MESSENGER_V2_ADDRESS=<cctp-v2-token-messenger-address>
CCTP_MESSAGE_TRANSMITTER_V2_ADDRESS=<cctp-v2-message-transmitter-address>
CCTP_TRANSFER_MODE=standard
HYPERUNIT_API_URL=<hyperunit-api-url>
RELAY_API_URL=https://api.relay.link
RELAY_API_KEY=
NEAR_INTENTS_API_URL=https://1click.chaindefuser.com
NEAR_INTENTS_API_KEY=
NEAR_INTENTS_BEARER_TOKEN=
MAYAN_API_URL=https://price-api.mayan.finance/v3
MAYAN_API_KEY=
CHAINFLIP_API_URL=https://chainflip-swap.chainflip.io
GARDEN_API_URL=https://api.garden.finance/v2
GARDEN_API_KEY=<garden-api-key>
CHANGENOW_API_URL=https://api.changenow.io
CHANGENOW_API_KEY=<changenow-api-key>
CHANGENOW_PROXY_URL=
# Dedicated Europe-pinned HyperUnit SOCKS5 proxy for router/worker execution.
HYPERUNIT_PROXY_URL=<socks5://user:password@hyperunit-eu-host:port>
# General SOCKS5 fallback for router upstreams. Set provider-specific *_PROXY_URL
# values below only when an upstream needs a different egress path.
UPSTREAM_PROXY_URL=<socks5://user:password@upstream-host:port>
ETH_RPC_PROXY_URL=
BASE_RPC_PROXY_URL=
ARBITRUM_RPC_PROXY_URL=
BITCOIN_RPC_PROXY_URL=
ESPLORA_PROXY_URL=
ACROSS_PROXY_URL=
CCTP_PROXY_URL=
HYPERLIQUID_PROXY_URL=
VELORA_PROXY_URL=
RELAY_PROXY_URL=
NEAR_INTENTS_PROXY_URL=
MAYAN_PROXY_URL=
CHAINFLIP_PROXY_URL=
GARDEN_PROXY_URL=
CHAINALYSIS_PROXY_URL=
COINBASE_PROXY_URL=
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_NETWORK=mainnet
VELORA_API_URL=https://api.velora.xyz
COINBASE_PRICE_API_BASE_URL=https://api.coinbase.com

# Conservative live-local sidecar defaults.
EVM_RECEIPT_WATCHER_POLL_INTERVAL_MS=2000
BITCOIN_INDEXER_POLL_INTERVAL_MS=2000
BITCOIN_RECEIPT_WATCHER_POLL_INTERVAL_MS=2000
HL_SHIM_WEIGHT_BUDGET_PER_MIN=900
HL_SHIM_WORKER_COUNT=16
HL_SHIM_MAX_DB_CONNECTIONS=50
