ture\",\"type\":\"tuple\"}],\"internalType\":\"struct MockHyperliquidBridge2.DepositWithPermit[]\",\"name\":\"deposits\",\"type\":\"tuple[]\"}],\"name\":\"batchedDepositWithPermit\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"user\",\"type\":\"address\"},{\"internalType\":\"uint64\",\"name\":\"usd\",\"type\":\"uint64\"}],\"name\":\"release\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"usdcToken\",\"outputs\":[{\"internalType\":\"contract IERC20PermitMinimal\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{},\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"release(address,uint64)\":{\"notice\":\"Mock-only withdrawal payout path. Real Hyperliquid Bridge2 payouts are validator-driven: `batchedRequestWithdrawals` emits `RequestedWithdrawal`, then after a dispute period validators call `finalizeWithdrawals` which emits `FinalizedWithdrawal`. The devnet mock compresses both steps into one call so the mock server has a single trigger for the on-chain effect, but emits BOTH real events so observers see the same event sequence they'd see on mainnet.\"}},\"notice\":\"Minimal Bridge2-compatible mock for devnet/testing. Event and struct shapes mirror Hyperliquid's real `Bridge2.sol` (at `0x2df1c51e09aecf9cacb7bc98cb1742757f163df7` mainnet) byte-for-byte so observers exercise the same ABI they see on mainnet:   - `Signature { uint256 r; uint256 s; uint8 v; }`  (r, s, v field order)   - `FailedPermitDeposit(address user, uint64 usd, uint32 errorCode)`   - `RequestedWithdrawal(address indexed user, address destination,       uint64 usd, uint64 nonce, bytes32 message, uint64 requestedTime)`   - `FinalizedWithdrawal(address indexed user, address destination,       uint64 usd, uint64 nonce, bytes32 message)` Note: real `Bridge2` declares `Deposit(address indexed user, uint64 usd)` but **never emits it** \\u2014 successful deposits are silent at the Bridge2 layer; observers credit balances from the USDC `Transfer` log into the bridge address. The mock previously emitted `Deposit` on permit success (a fabrication); now it matches reality and emits nothing on success.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/MockHyperliquidBridge2.sol\":\"MockHyperliquidBridge2\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"]},\"sources\":{\"src/MockHyperliquidBridge2.sol\":{\"keccak256\":\"0x2f69dda6f1e067062ae774baa7f1a84065fb853e3191ca09c267f6a458ced64a\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://11951cfca43f0fecb3c544e8ca2f73404183b156a6612182b5b74f87803c579e\",\"dweb:/ipfs/QmefMZPXAuzXMo7dh9TW8ATVQ1xDerSVj8KbzNCKjDvFno\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.28+commit.7893614a"},"language":"Solidity","output":{"abi":[{"inputs":[{"internalType":"address","name":"usdcAddress","type":"address"}],"stateMutability":"nonpayable","type":"constructor"},{"inputs":[{"internalType":"address","name":"user","type":"address","indexed":false},{"internalType":"uint64","name":"usd","type":"uint64","indexed":false},{"internalType":"uint32","name":"errorCode","type":"uint32","indexed":false}],"type":"event","name":"FailedPermitDeposit","anonymous":false},{"inputs":[{"internalType":"address","name":"user","type":"address","indexed":true},{"internalType":"address","name":"destination","type":"address","indexed":false},{"internalType":"uint64","name":"usd","type":"uint64","indexed":false},{"internalType":"uint64","name":"nonce","type":"uint64","indexed":false},{"internalType":"bytes32","name":"message","type":"bytes32","indexed":false}],"type":"event","name":"FinalizedWithdrawal","anonymous":false},{"inputs":[{"internalType":"address","name":"user","type":"address","indexed":true},{"internalType":"address","name":"destination","type":"address","indexed":false},{"internalType":"uint64","name":"usd","type":"uint64","indexed":false},{"internalType":"uint64","name":"nonce","type":"uint64","indexed":false},{"internalType":"bytes32","name":"message","type":"bytes32","indexed":false},{"internalType":"uint64","name":"requestedTime","type":"uint64","indexed":false}],"type":"event","name":"RequestedWithdrawal","anonymous":false},{"inputs":[{"internalType":"struct MockHyperliquidBridge2.DepositWithPermit[]","name":"deposits","type":"tuple[]","components":[{"internalType":"address","name":"user","type":"address"},{"internalType":"uint64","name":"usd","type":"uint64"},{"internalType":"uint64","name":"deadline","type":"uint64"},{"internalType":"struct MockHyperliquidBridge2.Signature","name":"signature","type":"tuple","components":[{"internalType":"uint256","name":"r","type":"uint256"},{"internalType":"uint256","name":"s","type":"uint256"},{"internalType":"uint8","name":"v","type":"uint8"}]}]}],"stateMutability":"nonpayable","type":"function","name":"batchedDepositWithPermit"},{"inputs":[{"internalType":"address","name":"user","type":"address"},{"internalType":"uint64","name":"usd","type":"uint64"}],"stateMutability":"nonpayable","type":"function","name":"release"},{"inputs":[],"stateMutability":"view","type":"function","name":"usdcToken","outputs":[{"internalType":"contract IERC20PermitMinimal","name":"","type":"address"}]}],"devdoc":{"kind":"dev","methods":{},"version":1},"userdoc":{"kind":"user","methods":{"release(address,uint64)":{"notice":"Mock-only withdrawal payout path. Real Hyperliquid Bridge2 payouts are validator-driven: `batchedRequestWithdrawals` emits `RequestedWithdrawal`, then after a dispute period validators call `finalizeWithdrawals` which emits `FinalizedWithdrawal`. The devnet mock compresses both steps into one call so the mock server has a single trigger for the on-chain effect, but emits BOTH real events so observers see the same event sequence they'd see on mainnet."}},"version":1}},"settings":{"remappings":["forge-std/=lib/forge-std/src/"],"optimizer":{"enabled":false,"runs":200},"metadata":{"bytecodeHash":"ipfs"},"compilationTarget":{"src/MockHyperliquidBridge2.sol":"MockHyperliquidBridge2"},"evmVersion":"prague","libraries":{}},"sources":{"src/MockHyperliquidBridge2.sol":{"keccak256":"0x2f69dda6f1e067062ae774baa7f1a84065fb853e3191ca09c267f6a458ced64a","urls":["bzz-raw://11951cfca43f0fecb3c544e8ca2f73404183b156a6612182b5b74f87803c579e","dweb:/ipfs/QmefMZPXAuzXMo7dh9TW8ATVQ1xDerSVj8KbzNCKjDvFno"],"license":"MIT"}},"version":1},"id":0}