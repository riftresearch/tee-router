{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "etc/Dockerfile.rathole-broker",
    "watchPatterns": ["etc/Dockerfile.rathole-broker", "deploy/railway/sauron/**"]
  },
  "deploy": { "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 10, "numReplicas": 1 }
}
