{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "etc/Dockerfile.bitcoin-receipt-watcher",
    "watchPatterns": [
      "bitcoin-receipt-watcher/**",
      "crates/**",
      "Cargo.toml",
      "Cargo.lock",
      "etc/Dockerfile.bitcoin-receipt-watcher"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1
  }
}
