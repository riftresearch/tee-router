# bitcoin-indexer-v3 — service-local.
# shared refs: BITCOIN_RPC_URL->BITCOIN_INDEXER_RPC_URL, BITCOIN_RPC_AUTH->_RPC_AUTH,
#   ELECTRUM_HTTP_SERVER_URL->BITCOIN_INDEXER_ESPLORA_URL, ZMQ_*->BITCOIN_INDEXER_ZMQ_*
RUST_LOG=info
BITCOIN_INDEXER_NETWORK=bitcoin
BITCOIN_INDEXER_BIND=[::]:8080
BITCOIN_INDEXER_POLL_INTERVAL_MS=2000
