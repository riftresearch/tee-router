# router-gateway-v3 — service-local.
# shared refs: ROUTER_GATEWAY_API_KEY, ROUTER_INTERNAL_BASE_URL, ETH_RPC_URL, BASE_RPC_URL, ARBITRUM_RPC_URL
#   (ETH/BASE/ARBITRUM_RPC_URL read ERC-20 decimals() for address-form tokens.)
# reference: ROUTER_GATEWAY_DATABASE_URL (${{router-gateway-db-v3.DATABASE_URL}})
# reference: REDIS_URL (redis://${{redis-v3.RAILWAY_PRIVATE_DOMAIN}}:6379) — forever decimals cache
HOST=::
PORT=4000
ROUTER_GATEWAY_PUBLIC_BASE_URL=CHANGEME_PUBLIC_GATEWAY_DOMAIN
ROUTER_GATEWAY_BITCOIN_ADDRESS_NETWORKS=mainnet
ROUTER_GATEWAY_CANCELLATION_SECRET_KEY=CHANGEME_GEN  # openssl rand -hex 32
