# Project-level SHARED vars → Railway project shared variables, consumed as
# ${{shared.NAME}}. Copy to _shared.env (gitignored) and fill.
# Legend: [have] reuse from .env.phala.prod/.env  [gen] tooling-generated
#         [PROCURE] external, must obtain         [deploy] resolved at deploy

# --- cross-service API keys / tokens ---
OBS_INGEST_TOKEN=                 # [have] must equal .env.phala.prod value
ROUTER_DETECTOR_API_KEY=          # [have]
ROUTER_ADMIN_API_KEY=             # [have]
ROUTER_GATEWAY_API_KEY=           # [have]
TOKEN_INDEXER_API_KEY=            # [gen]  == each indexer EVM_TOKEN_INDEXER_API_KEY
HL_SHIM_API_KEY=                  # [gen]

# --- chain RPC (HTTP) ---
ETH_RPC_URL=                      # [have]
BASE_RPC_URL=                     # [have]
ARBITRUM_RPC_URL=                 # [have]

# --- chain RPC (WS) — required by receipt-watchers + ponder ---
ETH_WS_RPC_URL=                   # [PROCURE]
BASE_WS_RPC_URL=                  # [PROCURE]
ARBITRUM_WS_RPC_URL=              # [PROCURE]

# --- bitcoin ---
BITCOIN_RPC_URL=                  # [have]
BITCOIN_RPC_AUTH=                 # [have]
BITCOIN_ZMQ_RAWBLOCK_ENDPOINT=    # [have? verify prod broker]
BITCOIN_ZMQ_RAWTX_ENDPOINT=       # [have? verify prod broker]
BITCOIN_ZMQ_SEQUENCE_ENDPOINT=    # [have? verify prod broker]
ELECTRUM_HTTP_SERVER_URL=         # [have]

# --- CDC (fixed convention; must match Phala migrations) ---
ROUTER_CDC_PUBLICATION_NAME=router_cdc_publication
ROUTER_CDC_MESSAGE_PREFIX=rift.router.change

# --- cross-platform (resolved at deploy) ---
ROUTER_INTERNAL_BASE_URL=         # [deploy] Phala router-api public URL (post-Phala)
