# sauron-bitcoin-rathole-broker-v3 — service-local secrets.
# 3 rathole service tokens; MUST match the rathole CLIENT running on the
# isolated bitcoin host (deploy/railway/sauron, etc/Dockerfile.rathole-client).
# Generate: openssl rand -hex 32  (one per feed)
RATHOLE_BITCOIN_RPC_TOKEN=CHANGEME_GEN
RATHOLE_ZMQ_RAWTX_TOKEN=CHANGEME_GEN
RATHOLE_ZMQ_SEQUENCE_TOKEN=CHANGEME_GEN
# Optional (defaults shown): control plane + private feed bind ports
RATHOLE_CONTROL_PORT=2333
RATHOLE_TRANSPORT_TYPE=websocket
RATHOLE_WEBSOCKET_TLS=false
RATHOLE_BITCOIN_RPC_BIND_PORT=40031
RATHOLE_ZMQ_RAWTX_BIND_PORT=40032
RATHOLE_ZMQ_SEQUENCE_BIND_PORT=40033
