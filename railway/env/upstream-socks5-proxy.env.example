# upstream-socks5-proxy-v3 — service-local. General router upstream SOCKS5
# egress proxy in the normal Railway region. Phala uses this service's public
# TCP proxy as UPSTREAM_PROXY_URL.
# socks5:// only (never socks5h://).
PROXY_USER=router
PROXY_PASSWORD=CHANGEME_GEN          # openssl rand -hex 24
# REQUIRE_AUTH / PROXY_PORT set by bootstrap.sh.
