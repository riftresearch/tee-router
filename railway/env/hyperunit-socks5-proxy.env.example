# hyperunit-socks5-proxy-v3 — service-local. Dedicated HyperUnit egress
# proxy (Europe). The router builds HYPERUNIT_PROXY_URL=socks5://USER:PASS@
# <svc>.railway.internal:1080 from these. socks5:// only (never socks5h://).
PROXY_USER=router
PROXY_PASSWORD=CHANGEME_GEN          # openssl rand -hex 24
# REQUIRE_AUTH / PROXY_PORT set by bootstrap.sh. Region: europe-west4-drams3a.
