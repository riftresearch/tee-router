# hyperunit-socks5-proxy-v3 — service-local. Shared upstream SOCKS5 egress
# proxy (Europe). Phala sets UPSTREAM_PROXY_URL from the public TCP proxy; Sauron
# uses the same service as HYPERUNIT_PROXY_URL for its HyperUnit observer.
# socks5:// only (never socks5h://).
PROXY_USER=router
PROXY_PASSWORD=CHANGEME_GEN          # openssl rand -hex 24
# REQUIRE_AUTH / PROXY_PORT set by bootstrap.sh. Region: europe-west4-drams3a.
