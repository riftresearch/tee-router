# admin-dashboard-v3 — service-local.
# shared refs: ROUTER_ADMIN_API_KEY ROUTER_CDC_PUBLICATION_NAME ROUTER_CDC_MESSAGE_PREFIX
# reference: ADMIN_DASHBOARD_{AUTH,ANALYTICS,REPLICA}_DATABASE_URL
HOST=::
PORT=3000
NODE_ENV=production
ADMIN_DASHBOARD_PRODUCTION=true
ADMIN_DASHBOARD_ALLOW_INSECURE_DEV_AUTH_BYPASS=false
ADMIN_DASHBOARD_WEB_ORIGIN=CHANGEME_PUBLIC_DASHBOARD_DOMAIN
ADMIN_DASHBOARD_CDC_SLOT_NAME=admin_dashboard_orders_cdc
BETTER_AUTH_URL=CHANGEME_PUBLIC_DASHBOARD_DOMAIN
BETTER_AUTH_SECRET=CHANGEME_GEN  # openssl rand -hex 32
GOOGLE_CLIENT_ID=CHANGEME_FROM_.env.admin
GOOGLE_CLIENT_SECRET=CHANGEME_FROM_.env.admin
SUPABASE_CHATS_URL=CHANGEME_PROCURE_SUPABASE
SUPABASE_ANON_KEY=CHANGEME_PROCURE_SUPABASE
SUPABASE_CHAT_ADMIN_SECRET=CHANGEME_PROCURE_SUPABASE
