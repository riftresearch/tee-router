# sauron-worker-v3 — service-local vars only.
# shared refs (bootstrap → ${{shared.X}}): ETH_RPC_URL BASE_RPC_URL ARBITRUM_RPC_URL
#   BITCOIN_RPC_URL BITCOIN_RPC_AUTH BITCOIN_ZMQ_* ESPLORA_HTTP_SERVER_URL
#   ROUTER_DETECTOR_API_KEY TOKEN_INDEXER_API_KEY ROUTER_CDC_PUBLICATION_NAME
#   ROUTER_CDC_MESSAGE_PREFIX ROUTER_INTERNAL_BASE_URL HYPERUNIT_API_URL
# reference vars (bootstrap → ${{svc.X}}): ROUTER_REPLICA_DATABASE_URL
#   SAURON_STATE_DATABASE_URL HL_SHIM_INDEXER_URL BITCOIN_INDEXER_URL
#   BITCOIN_RECEIPT_WATCHER_URL {ETHEREUM,BASE,ARBITRUM}_RECEIPT_WATCHER_URL
#   {ETHEREUM,BASE,ARBITRUM}_TOKEN_INDEXER_URL
RUST_LOG=info
METRICS_BIND_ADDR=0.0.0.0:9102
SAURON_REPLICA_EVENT_SOURCE=cdc
SAURON_CDC_SLOT_NAME=sauron_watch_cdc
SAURON_BITCOIN_SCAN_INTERVAL_SECONDS=5
SAURON_HL_BRIDGE_MATCH_WINDOW_SECONDS=120
SAURON_HU_POLL_FAST_MILLIS=1000
SAURON_HU_POLL_MEDIUM_MILLIS=5000
SAURON_HU_POLL_SLOW_MILLIS=30000
