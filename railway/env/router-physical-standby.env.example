# router-physical-standby-v3 — points at the Phala primary via stunnel.
# shared ref: PRIMARY_DB_PASSWORD = POSTGRES_REPLICA_PASSWORD (from .env.phala.prod)
PGDATA=/var/lib/postgresql/18/docker
PRIMARY_DB_HOST=CHANGEME_PHALA_DB_STUNNEL_HOST
PRIMARY_DB_PORT=5432
PRIMARY_DB_NAME=router_db
PRIMARY_DB_USER=replicator
PRIMARY_DB_SSLMODE=disable
PRIMARY_REPLICATION_SLOT=router_physical_standby_v3
STANDBY_APPLICATION_NAME=router-physical-standby-v3
STANDBY_MAX_CONNECTIONS=400
