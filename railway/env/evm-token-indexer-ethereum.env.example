# evm-token-indexer-ethereum-v3 (Ponder) — service-local.
# shared refs: ETHEREUM_RPC_URL->PONDER_RPC_URL_HTTP, ETHEREUM_WS_RPC_URL->PONDER_WS_URL_HTTP,
#   TOKEN_INDEXER_API_KEY->EVM_TOKEN_INDEXER_API_KEY
# reference: DATABASE_URL (managed PG)
PONDER_CHAIN_ID=1
PONDER_CONTRACT_START_BLOCK=CHANGEME
PONDER_SCHEMA=tokens_ethereum
DATABASE_SCHEMA=tokens_ethereum
PONDER_PORT=4001
PONDER_LOG_LEVEL=info
PONDER_DISABLE_CACHE=false
EVM_TOKEN_INDEXER_RAW_RETENTION_SECONDS=604800
EVM_TOKEN_INDEXER_REORG_SAFE_BLOCKS=64
EVM_TOKEN_INDEXER_WS_MAX_BUFFERED_BYTES=8388608
